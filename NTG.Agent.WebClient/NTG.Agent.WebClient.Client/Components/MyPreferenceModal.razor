@using NTG.Agent.Common.Dtos.Agents
@using NTG.Agent.Common.Dtos.UserPreferences
@using NTG.Agent.WebClient.Client.Services
@inject PreferenceClient PreferenceClient
@inject ChatClient ChatClient
@inject IJSRuntime JS
@inject ILogger<MyPreferenceModal> Logger
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<div class="modal-overlay" @onclick="@(() => OnClose.InvokeAsync())">
    <div class="preference-modal" @onclick:stopPropagation>
        <div class="modal-header">
            <h3 class="modal-title">⚙️ My Preferences</h3>
            <button class="close-button" @onclick="@(() => OnClose.InvokeAsync())">×</button>
        </div>

        <div class="modal-content-area">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">
                    <strong>Error:</strong> @errorMessage
                </div>
            }

            @if (isLoading)
            {
                <div class="loading-section">
                    <div class="spinner"></div>
                    <p>Loading preferences...</p>
                </div>
            }
            else
            {
                <!-- General Section -->
                <div class="settings-card">
                    <h4>🎨 General</h4>

                    <!-- Appearance -->
                    <div class="setting-item">
                        <label class="setting-label">
                            <span class="label-text">Appearance:</span>
                        </label>
                        <div class="appearance-options">
                            <button class="appearance-option @(selectedTheme == "light" ? "active" : "")"
                                    @onclick="OnThemeLightChanged">
                                <span class="appearance-icon">☀️</span>
                                <span class="appearance-label">Light</span>
                            </button>
                            <button class="appearance-option @(selectedTheme == "dark" ? "active" : "")"
                                    @onclick="OnThemeDarkChanged">
                                <span class="appearance-icon">🌙</span>
                                <span class="appearance-label">Dark</span>
                            </button>
                        </div>
                    </div>

                    <!-- Accent Color -->
                    <div class="setting-item">
                        <label class="setting-label">
                            <span class="label-text">Accent Color:</span>
                        </label>
                        <div class="color-swatches">
                            @foreach (var color in accentColors)
                            {
                                // Capture loop variable so the lambda closes over the correct key
                                var colorKey = color.Key;
                                <button class="color-swatch @(selectedAccent == color.Key ? "selected" : "")"
                                        style="background-color: @color.Value;"
                                        title="@color.Key"
                                        @onclick="() => OnAccentChanged(colorKey)">
                                    @if (selectedAccent == color.Key)
                                    {
                                        <svg class="swatch-check" viewBox="0 0 16 16" fill="white">
                                            <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z"/>
                                        </svg>
                                    }
                                </button>
                            }
                        </div>
                        <p class="setting-description">Accent color affects buttons, links, and interactive highlights.</p>
                    </div>
                </div>

                <!-- Agent Selection Section -->
                <div class="settings-card">
                    <h4>🤖 Agent Selection</h4>
                    <div class="setting-item">
                        <label class="setting-label">
                            <span class="label-text">Preferred Agent:</span>
                        </label>
                        <select class="agent-selector" @bind="selectedAgentId" @bind:after="OnAgentChanged">
                            <option value="@Guid.Empty">-- Select an Agent --</option>
                            @foreach (var agent in availableAgents)
                            {
                                <option value="@agent.Id">@agent.Name @(agent.IsDefault ? "(Default)" : "")</option>
                            }
                        </select>
                        <p class="setting-description">
                            Choose which AI agent you want to chat with. Each agent has different capabilities and personalities.
                        </p>
                    </div>
                </div>

                <!-- Memory Settings Section -->
                <div class="settings-card">
                    <h4>🧠 Memory Settings</h4>
                    <div class="setting-item">
                        <label class="toggle-label">
                            <input type="checkbox" 
                                   class="toggle-checkbox"
                                   @bind="isMemoryEnabled" 
                                   @bind:after="OnMemoryToggleChanged" />
                            <span class="toggle-slider"></span>
                            <span class="toggle-text">Long-Term Memory: <strong>@(isMemoryEnabled ? "ON" : "OFF")</strong></span>
                        </label>
                        <p class="setting-description">
                            @if (isMemoryEnabled)
                            {
                                <span>✅ The AI will learn from your conversations to provide personalized responses.</span>
                            }
                            else
                            {
                                <span>❌ Memory learning is disabled. The AI won't remember new information.</span>
                            }
                        </p>
                    </div>
                    
                    <div class="setting-item">
                        <label class="toggle-label">
                            <input type="checkbox" 
                                   class="toggle-checkbox"
                                   @bind="isMemorySearchEnabled" 
                                   @bind:after="OnMemorySearchToggleChanged" />
                            <span class="toggle-slider"></span>
                            <span class="toggle-text">Memory Search: <strong>@(isMemorySearchEnabled ? "ON" : "OFF")</strong></span>
                        </label>
                        <p class="setting-description">
                            @if (isMemorySearchEnabled)
                            {
                                <span>✅ Saved memories will be used to provide context in conversations.</span>
                            }
                            else
                            {
                                <span>❌ Saved memories won't be retrieved. The AI will respond without memory context.</span>
                            }
                        </p>
                    </div>
                </div>

                @if (isSaving)
                {
                    <div class="status-message">Saving preferences...</div>
                }
                else if (!string.IsNullOrEmpty(statusMessage))
                {
                    <div class="status-message success">@statusMessage</div>
                }
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnClose { get; set; }

    private bool isLoading = true;
    private bool isSaving = false;
    private string? errorMessage;
    private string? statusMessage;

    private List<AgentListItemDto> availableAgents = new();
    private Guid selectedAgentId = Guid.Empty;
    private bool isMemoryEnabled = true;
    private bool isMemorySearchEnabled = true;

    // General settings
    private string selectedTheme = "light";
    private string selectedAccent = "default";

    // Accent color palette: key maps to the [data-accent] CSS attribute value
    private static readonly Dictionary<string, string> accentColors = new()
    {
        ["default"] = "#6c757d",
        ["violet"]  = "#7c3aed",
        ["green"]   = "#16a34a",
        ["yellow"]  = "#ca8a04",
        ["orange"]  = "#ea580c"
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;

            // Load available agents
            await LoadAgentsAsync();

            // Load current preferences
            await LoadPreferencesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading preferences");
            errorMessage = "Failed to load preferences. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadAgentsAsync()
    {
        try
        {
            availableAgents = await ChatClient.GetAgentsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading agents");
            errorMessage = "Failed to load available agents.";
        }
    }

    private async Task LoadPreferencesAsync()
    {
        try
        {
            // Read cached theme/accent from localStorage first for instant UI consistency
            selectedTheme  = await JS.InvokeAsync<string>("getTheme");
            selectedAccent = await JS.InvokeAsync<string>("getAccentColor");

            var preference = await PreferenceClient.GetPreferenceAsync(null);
            if (preference != null)
            {
                selectedAgentId = preference.SelectedAgentId;
                // Default to true if null (for anonymous users)
                isMemoryEnabled = preference.IsLongTermMemoryEnabled ?? true;
                isMemorySearchEnabled = preference.IsMemorySearchEnabled ?? true;

                // DB is source of truth — apply and sync to localStorage if different
                var dbTheme  = preference.AppearanceTheme ?? "light";
                var dbAccent = preference.AccentColor ?? "default";

                if (dbTheme != selectedTheme)
                {
                    selectedTheme = dbTheme;
                    await JS.InvokeVoidAsync("setTheme", dbTheme);
                }

                if (dbAccent != selectedAccent)
                {
                    selectedAccent = dbAccent;
                    await JS.InvokeVoidAsync("setAccentColor", dbAccent);
                }
            }
            else if (availableAgents.Count > 0)
            {
                // Select default agent if no preference exists
                var defaultAgent = availableAgents.FirstOrDefault(a => a.IsDefault) ?? availableAgents.First();
                selectedAgentId = defaultAgent.Id;
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading preferences");
            // Don't show error for missing preferences, just use defaults
        }
    }

    private async Task OnAgentChanged()
    {
        await SavePreferencesAsync();
    }

    private async Task OnMemoryToggleChanged()
    {
        await SavePreferencesAsync();
    }

    private async Task OnMemorySearchToggleChanged()
    {
        await SavePreferencesAsync();
    }

    private Task OnThemeLightChanged() => OnThemeChanged("light");
    private Task OnThemeDarkChanged() => OnThemeChanged("dark");

    private async Task OnThemeChanged(string theme)
    {
        selectedTheme = theme;
        // Apply immediately and cache in localStorage
        await JS.InvokeVoidAsync("setTheme", theme);
        await SavePreferencesAsync();
    }

    private async Task OnAccentChanged(string accent)
    {
        selectedAccent = accent;
        // Apply immediately and cache in localStorage
        await JS.InvokeVoidAsync("setAccentColor", accent);
        await SavePreferencesAsync();
    }

    private async Task SavePreferencesAsync()
    {
        try
        {
            isSaving = true;
            statusMessage = null;
            errorMessage = null;

            var success = await PreferenceClient.SavePreferenceAsync(
                selectedAgentId,
                isMemoryEnabled,
                isMemorySearchEnabled,
                null,
                selectedTheme,
                selectedAccent
            );

            if (success)
            {
                statusMessage = "Preferences saved successfully!";
                
                // Clear success message after 3 seconds
                _ = Task.Delay(3000).ContinueWith(_ => 
                {
                    statusMessage = null;
                    StateHasChanged();
                });
            }
            else
            {
                errorMessage = "Failed to save preferences. Please try again.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error saving preferences");
            errorMessage = "Failed to save preferences. Please try again.";
        }
        finally
        {
            isSaving = false;
        }
    }
}
